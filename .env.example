# Repository-safe config template.
# Keep live secrets in .env.local or point SUPPLY_BOT_CONFIG to a private file.

# Bot settings
BOT_TOKEN=your_bot_token_here
DEBUG=False
ADMIN_PASSWORD_HASH=your_admin_password_hash_here
ADMIN_SESSION_SECRET=your_admin_session_secret_here
ADMIN_SESSION_TTL_SECONDS=43200

# Tasks settings
TASKS_SOURCE=local
TASKS_FILE=./data/tasks/tasks.xlsx
TASKS_SHEET_NAME=Tasks
TIMEZONE=Europe/Berlin

# Team settings
TEAM_GROUP_CHAT_ID=-100123456789
ADMIN_IDS=660806742

# Notification settings
QUIET_HOURS_START=22:00
QUIET_HOURS_END=08:00

# Integration settings
SHEETS_CREDENTIALS=./a_settings/credentials.json
NOTION_TOKEN=your_notion_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1
SUPPLY_DIALOGUE_ENABLED=True
SUPPLY_DIALOGUE_PRIMARY_PROVIDER=openai
SUPPLY_DIALOGUE_MODEL=gpt-5.4
SUPPLY_DIALOGUE_REASONING_EFFORT=low
SUPPLY_DIALOGUE_MAX_OUTPUT_TOKENS=320
SUPPLY_DIALOGUE_MISTRAL_MODEL=mistral-large-latest
SUPPLY_DIALOGUE_MISTRAL_MAX_OUTPUT_TOKENS=320
SUPPLY_DIALOGUE_MISTRAL_TIMEOUT_SECONDS=25
PROJECT_DOCUMENTS_DIR=./data/project-documents
