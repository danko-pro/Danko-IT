# Production environment template. Put real values only in the hosting provider env/secret UI.
# Do not commit .env.local, real .env files, tokens, passwords, or API keys.

# Shared backend / worker runtime
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE
ADMIN_SESSION_SECRET=replace-with-output-of-python-secrets-token-urlsafe-64
ADMIN_SESSION_COOKIE_SECURE=True
ADMIN_SESSION_COOKIE_SAMESITE=None
ADMIN_API_CORS_ORIGINS=https://danko39.ru,https://www.danko39.ru

# Telegram bot worker
BOT_TOKEN=replace-with-telegram-bot-token

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# File storage
FILE_STORAGE_BACKEND=local
PROJECT_DOCUMENTS_DIR=/app/data/project-documents

# Frontend static site
VITE_API_BASE_URL=https://api.danko39.ru

# Optional production settings
DEBUG=False
TIMEZONE=Europe/Berlin
ADMIN_SESSION_TTL_SECONDS=43200
PROJECT_DOCUMENT_MAX_UPLOAD_BYTES=26214400

# Optional legacy/platform-admin login. Leave empty unless intentionally enabled.
ADMIN_PASSWORD_HASH=

# Optional AI providers. Leave empty unless enabled in production.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Optional supply dialogue settings.
SUPPLY_DIALOGUE_ENABLED=True
SUPPLY_DIALOGUE_PRIMARY_PROVIDER=openai
SUPPLY_DIALOGUE_MODEL=gpt-5.4
SUPPLY_DIALOGUE_REASONING_EFFORT=low
SUPPLY_DIALOGUE_MAX_OUTPUT_TOKENS=320
REQUEST_DRAFT_STALE_HOURS=24
TELEGRAM_MEDIA_MAX_DOWNLOAD_BYTES=26214400
